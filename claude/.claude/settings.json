{
  "permissions": {
    "allow": [
      "Read(~/CLAUDE.md)",
      "Read(~/repos/**)",
      "Read(~/datasets/**)",
      "Read(~/git/**)",
      "Read(~/notebooks/**)",
      "Edit(~/repos/**)",
      "Edit(~/notebooks/**)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(uv:*)",
      "Bash(make:*)",
      "Bash(cargo:*)",
      "WebFetch"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "auto"
  },
  "model": "opus",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true
}
