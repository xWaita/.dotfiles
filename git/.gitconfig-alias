[alias]
    s  = status
    d  = diff
    f  = fetch
    l  = log
    r  = rebase
    a  = add .
    c  = commit -m
    p  = push
    fixup = !git add -A && git commit --amend --no-edit
    acp = "!f() { git add . && git commit -m \"$1\" && git push; }; f"
    co  = "!f() { git checkout \"$1\" && git pull; }; f"
    cb  = "!f() { git checkout -b \"$1\"; }; f"

